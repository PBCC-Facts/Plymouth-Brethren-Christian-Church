# Public read path (client + server). Publishable/anon key: sees only what RLS
# exposes. Safe to expose.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Canonical origin (no trailing slash). Optional; defaults to https://pbccfacts.com
NEXT_PUBLIC_SITE_URL=

# --- Contact intake (/contact), server-only. Never NEXT_PUBLIC. -------------

# Service-role key. Used ONLY by src/app/api/intake/* to write submissions and
# mint signed upload URLs. Full DB access: keep secret, set in Vercel as an
# encrypted env var, never commit. The intake form degrades gracefully when
# this is absent (submissions disabled, other channels still shown).
SUPABASE_SERVICE_ROLE_KEY=

# HMAC secret for the intake form's signed time token (anti-bot). Any long
# random string, e.g. `node -e "console.log(crypto.randomBytes(32).toString('hex'))"`.
INTAKE_TOKEN_SECRET=
