# Copy to .env.secrets (gitignored), fill in, then run:
#   ./scripts/push-secrets.sh
# That pushes each non-empty value to Vercel (production + preview) and
# triggers a redeploy prompt.

# Resend API key (resend.com, demantive account, domain mail.pbccfacts.com).
# Create a key scoped to "Sending access" on that domain only.
RESEND_API_KEY=

# Slack incoming webhook URL for the channel that should get form alerts.
SLACK_WEBHOOK_URL=

# Comma-separated team addresses that get the metadata-only email alert.
INTAKE_NOTIFY_TO=

# Optional. From header for all outbound mail. Defaults to:
#   The Facts <intake@mail.pbccfacts.com>
INTAKE_FROM_EMAIL=
